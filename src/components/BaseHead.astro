---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Sam Baldwin",
  description = "Sam Baldwin — fourth-year Data Science student at Northeastern University. Personal portfolio, projects, and resume.",
  image = "/headshot.jpg",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site).toString();

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Samuel Baldwin",
  alternateName: "Sam Baldwin",
  url: Astro.site?.toString(),
  image: ogImage,
  jobTitle: "App Developer",
  alumniOf: {
    "@type": "CollegeOrUniversity",
    name: "Northeastern University",
  },
  sameAs: [
    "https://www.linkedin.com/in/baldwinsamuel/",
    "https://github.com/samuelbaldwin05",
  ],
};
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />
<!-- Browser tabs: rounded-square SVG -->
<link rel="icon" href="/favicon.svg?v=5" type="image/svg+xml" sizes="any" />
<!-- Google search results target this 48x48-hinted entry; circle version avoids the white halo in their UI chip -->
<link rel="icon" href="/favicon-google.svg?v=5" type="image/svg+xml" sizes="48x48" />
<link rel="alternate icon" href="/favicon.svg?v=5" />
<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="Samuel Baldwin" />
<meta name="robots" content="index, follow" />
<meta name="theme-color" content="#2d6f4a" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:site_name" content="Sam Baldwin" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
